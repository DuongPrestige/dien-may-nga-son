generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  LOST
}

enum LeadSourceType {
  PRODUCT
  SERVICE
  BLOG
  CONTACT
  PROMOTION
  HOME
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash")
  role         UserRole @default(ADMIN)
  fullName     String?  @map("full_name") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model Category {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(255)
  description    String?
  seoTitle       String?   @map("seo_title") @db.VarChar(255)
  seoDescription String?   @map("seo_description")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  products       Product[]

  @@index([slug], map: "idx_categories_slug")
  @@map("categories")
}

model Brand {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  logoUrl     String?   @map("logo_url")
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@index([slug], map: "idx_brands_slug")
  @@map("brands")
}

model Product {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId       String         @map("category_id") @db.Uuid
  brandId          String         @map("brand_id") @db.Uuid
  name             String         @db.VarChar(255)
  slug             String         @unique @db.VarChar(255)
  sku              String?        @db.VarChar(100)
  price            Decimal        @db.Decimal(14, 2)
  salePrice        Decimal?       @map("sale_price") @db.Decimal(14, 2)
  thumbnailUrl     String?        @map("thumbnail_url")
  shortDescription String?        @map("short_description")
  description      String?
  isFeatured       Boolean        @default(false) @map("is_featured")
  status           ProductStatus  @default(ACTIVE)
  seoTitle         String?        @map("seo_title") @db.VarChar(255)
  seoDescription   String?        @map("seo_description")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  brand            Brand          @relation(fields: [brandId], references: [id])
  category         Category       @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
  specs            ProductSpec[]
  leads            Lead[]

  @@index([slug], map: "idx_products_slug")
  @@index([categoryId], map: "idx_products_category")
  @@index([brandId], map: "idx_products_brand")
  @@index([isFeatured], map: "idx_products_featured")
  @@map("products")
}

model ProductImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  imageUrl  String   @map("image_url")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "idx_product_images_product")
  @@map("product_images")
}

model ProductSpec {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  specName  String  @map("spec_name") @db.VarChar(255)
  specValue String  @map("spec_value")
  sortOrder Int     @default(0) @map("sort_order")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "idx_product_specs_product")
  @@map("product_specs")
}

model Service {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String        @db.VarChar(255)
  slug             String        @unique @db.VarChar(255)
  thumbnailUrl     String?       @map("thumbnail_url")
  shortDescription String?       @map("short_description")
  content          String?
  isFeatured       Boolean       @default(false) @map("is_featured")
  status           ProductStatus @default(ACTIVE)
  seoTitle         String?       @map("seo_title") @db.VarChar(255)
  seoDescription   String?       @map("seo_description")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  leads            Lead[]

  @@index([slug], map: "idx_services_slug")
  @@index([status], map: "idx_services_status")
  @@map("services")
}

model PostCategory {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  String @db.VarChar(255)
  slug  String @unique @db.VarChar(255)
  posts Post[]

  @@map("post_categories")
}

model Post {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId     String?       @map("category_id") @db.Uuid
  title          String        @db.VarChar(255)
  slug           String        @unique @db.VarChar(255)
  thumbnailUrl   String?       @map("thumbnail_url")
  excerpt        String?
  content        String
  isPublished    Boolean       @default(false) @map("is_published")
  publishedAt    DateTime?     @map("published_at")
  seoTitle       String?       @map("seo_title") @db.VarChar(255)
  seoDescription String?       @map("seo_description")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  category       PostCategory? @relation(fields: [categoryId], references: [id])

  @@index([slug], map: "idx_posts_slug")
  @@map("posts")
}

model Banner {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String   @db.VarChar(255)
  imageUrl  String   @map("image_url")
  targetUrl String?  @map("target_url")
  position  String?  @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banners")
}

model Lead {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String          @db.VarChar(255)
  phone      String          @db.VarChar(50)
  message    String?
  sourceType LeadSourceType? @map("source_type")
  sourceUrl  String?         @map("source_url")
  productId  String?         @map("product_id") @db.Uuid
  serviceId  String?         @map("service_id") @db.Uuid
  status     LeadStatus      @default(NEW)
  createdAt  DateTime        @default(now()) @map("created_at")
  product    Product?        @relation(fields: [productId], references: [id])
  service    Service?        @relation(fields: [serviceId], references: [id])

  @@index([phone], map: "idx_leads_phone")
  @@index([status], map: "idx_leads_status")
  @@map("leads")
}

model Setting {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  settingKey   String   @unique @map("setting_key") @db.VarChar(255)
  settingValue String?  @map("setting_value")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model SeoRedirect {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourcePath      String   @map("source_path")
  destinationPath String   @map("destination_path")
  redirectType    Int      @default(301) @map("redirect_type")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("seo_redirects")
}
